; ═════════════════════════════════════════════════════════════════════════════
; SCÈNE — Zone 1 : Sylvara, le Village des Lisières
;
; Layout radial centré sur l'Aelith (0, 0, 0).
; Entrée du village depuis le sud (+Z). Sortie vers Zone 2 au nord (-Z).
; Rayon du village : ~15m.
;
; Géométrie procédurale (maisons, puits, palissade) créée dans zone1.gd.
; ═════════════════════════════════════════════════════════════════════════════

[node name="Zone1" type="Node3D"]
script = ExtResource("1_zone1")

; ── L'Aelith ─────────────────────────────────────────────────────────────────
; Nimbus Willow au centre. Scale à ajuster si le modèle est trop petit/grand.
[node name="Aelith" parent="." instance=ExtResource("6_aelith")]
transform = Transform3D(6, 0, 0, 0, 6, 0, 0, 0, 6, 0, 0, 0)

; ── PNJ ───────────────────────────────────────────────────────────────────────
[node name="PNJ" type="Node3D" parent="."]

; Vaenmor — L'Ancien. Assis au pied de l'Aelith, côté sud-est.
; Son honorifique signifie "barbe cendre-vieux". Son vrai nom a été oublié.
; Récompense : fragment de lettre 1 + raccourci Zone 2 si l'Épreuve de l'Aelith est résolue.
[node name="Vaenmor" type="Node3D" parent="PNJ"]
position = Vector3(4.0, 0.0, 3.5)
script = ExtResource("2_pnj")
nom_pnj = "Vaenmor"
lignes = [
	"Vous avez les yeux de quelqu'un que j'ai connu.",
	"Drôle de chose à voir avant de mourir.",
	"Elle savait que vous viendriez. Elle m'a demandé de vous guetter."
]
flag_apres = "vaenmor_parle"

[node name="ZoneProximite" type="Area3D" parent="PNJ/Vaenmor"]

[node name="CollisionShape3D" type="CollisionShape3D" parent="PNJ/Vaenmor/ZoneProximite"]
shape = SubResource("ss_pnj")

; Lira — voisine, parle de l'oiseau blanc (déclenche Puzzle 2)
[node name="Lira" type="Node3D" parent="PNJ"]
position = Vector3(18.0, 0.0, 14.0)
script = ExtResource("2_pnj")
nom_pnj = "Lira"
lignes = [
	"Ah, vous êtes les enfants d'Elara...",
	"Cet oiseau blanc, sur le toit là-bas — il était toujours là quand elle rentrait.",
	"Il vous attend, je crois."
]
flag_apres = "lira_parlee"

[node name="ZoneProximite" type="Area3D" parent="PNJ/Lira"]

[node name="CollisionShape3D" type="CollisionShape3D" parent="PNJ/Lira/ZoneProximite"]
shape = SubResource("ss_pnj")

; Brennan — meunier, parle du mécanisme cassé (déclenche Puzzle 3)
[node name="Brennan" type="Node3D" parent="PNJ"]
position = Vector3(-20.0, 0.0, -12.0)
script = ExtResource("2_pnj")
nom_pnj = "Brennan"
lignes = [
	"La roue s'est arrêtée le jour où Elara est partie.",
	"Comme si elle retenait quelque chose.",
	"Il y avait une liane qui courait le long du mur, avant. Elle a disparu avec elle."
]
