; ═══════════════════════════════════════════════════════════════════════════════
; SCÈNE PRINCIPALE — Gwanur
;
; Un seul personnage actif (Kael par défaut), une seule caméra orbitale.
; Zone1 contient le village de départ (Sylvara) avec l'Aelith au centre.
;
; Kael démarre à (0, 0, 5) — entrée sud du village, face à l'Aelith.
; ═══════════════════════════════════════════════════════════════════════════════

[node name="Main" type="Node3D"]
script = ExtResource("1_main")

[node name="Monde" type="Node3D" parent="."]

[node name="Environnement" type="WorldEnvironment" parent="Monde"]
environment = SubResource("Env_001")

; Lumière du jour — légèrement chaude, ombres activées
[node name="LumiereDirectionnelle" type="DirectionalLight3D" parent="Monde"]
transform = Transform3D(1, 0, 0, 0, 0.707107, -0.707107, 0, 0.707107, 0.707107, 0, 10, 0)
light_color = Color(1, 0.952941, 0.8, 1)
light_energy = 1.2
shadow_enabled = true

; Kael — personnage actif, démarre à l'entrée du village
[node name="Kael" parent="Monde" instance=ExtResource("2_kael")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0, 5)

; Caméra orbitale — main.gd lui assigne Kael comme cible
[node name="Camera" type="Camera3D" parent="Monde"]
script = ExtResource("4_camera")

; Village de départ — Sylvara
[node name="Zone1" parent="Monde" instance=ExtResource("3_zone1")]

